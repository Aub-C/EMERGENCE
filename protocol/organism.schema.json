{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emergence.invalid/protocol/organism.schema.json",
  "title": "EMERGENCE Organism Contract",
  "type": "object",
  "required": ["protocol_version", "identity", "verify", "start", "health", "runtime"],
  "properties": {
    "protocol_version": { "type": "integer", "minimum": 1 },
    "identity": { "type": "string", "minLength": 1 },
    "install": { "$ref": "#/$defs/command" },
    "verify": { "$ref": "#/$defs/command" },
    "start": { "$ref": "#/$defs/command" },
    "health": {
      "type": "object",
      "required": ["path", "expected_status", "startup_timeout_ms"],
      "properties": {
        "path": { "type": "string", "pattern": "^/" },
        "expected_status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "startup_timeout_ms": { "type": "integer", "minimum": 100, "maximum": 120000 }
      },
      "additionalProperties": true
    },
    "runtime": {
      "type": "object",
      "required": ["port_env", "default_port"],
      "properties": {
        "port_env": { "type": "string", "minLength": 1 },
        "default_port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
